Task 9: Modern Containerization (Quadlets)
This is the new RHEL 10 standard. You must write a .container file.

Bash

su - sarah
podman pull docker.io/library/httpd:latest

# 1. Create the Quadlet directory
mkdir -p ~/.config/containers/systemd/
cd ~/.config/containers/systemd/

# 2. Write the Quadlet file
vim sarah_web.container
Add the following contents to sarah_web.container:

Ini, TOML

[Container]
Image=docker.io/library/httpd:latest
PublishPort=8080:80

[Service]
Restart=always

[Install]
WantedBy=default.target
Bash

# 3. Reload systemd to generate the service from the Quadlet
systemctl --user daemon-reload

# 4. Start and enable the service (Notice the name matches the file)
systemctl --user enable --now sarah_web.service

# 5. Enable lingering (as root)
exit
loginctl enable-linger sarah
