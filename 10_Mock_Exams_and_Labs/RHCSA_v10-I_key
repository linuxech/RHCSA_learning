Task 4: Storage Engineering (LVM)
Bash

pvcreate /dev/vdb
vgcreate -s 16M vg_server /dev/vdb
lvcreate -l 100 -n lv_metrics vg_server
mkfs.xfs /dev/vg_server/lv_metrics
mkdir -p /var/log/metrics
blkid /dev/vg_server/lv_metrics # Copy UUID
echo "UUID=<your_uuid> /var/log/metrics xfs defaults 0 0" >> /etc/fstab
mount -a
Task 5: Swap Allocation
Bash

fdisk /dev/vdc # Create a 1G partition, e.g., /dev/vdc1
mkswap /dev/vdc1
blkid /dev/vdc1 # Copy UUID
echo "UUID=<your_uuid> swap swap defaults 0 0" >> /etc/fstab
swapon -a
